      "title": "Distance (km) + Activities",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "strava-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH w AS (\n  SELECT date_trunc('month', start_date_local) AS time,\n         SUM(distance) / 1000.0 AS km,\n         COUNT(*) AS activities\n  FROM strava_integration_activity\n  WHERE $__timeFilter(start_date_local) AND activity_type = 'Ride'\n  GROUP BY 1\n),\nn AS (\n  SELECT time, km, activities,\n         ROW_NUMBER() OVER (ORDER BY time) - 1 AS rn\n  FROM w\n),\nr AS (\n  SELECT regr_slope(km, rn) AS slope, regr_intercept(km, rn) AS intercept FROM n\n)\nSELECT n.time,\n       n.km AS \"Distance (km)\",\n       n.activities AS \"Activities\",\n       r.intercept + r.slope * n.rn AS \"Trend (km)\",\n       260 AS \"Goal (260 km/mo)\"\nFROM n CROSS JOIN r\nORDER BY n.time",
          "refId": "A"
        }
      ]
    },
